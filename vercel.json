{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/blog/blog/:slug"
    },
    {
      "source": "/:slug*-ga",
      "destination": "/seo-pages/pages/:slug*-ga.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "calculator.lawnlogicturf.com"
        }
      ],
      "destination": "https://lawnlogicturf.com/instant-quote",
      "statusCode": 301
    },
    {
      "source": "/store-lawnlogic/:path*",
      "destination": "https://lawnlogic.squarespace.com/store-lawnlogic/:path*",
      "statusCode": 308
    },
    {
      "source": "/store",
      "destination": "https://lawnlogic.squarespace.com/store-lawnlogic",
      "statusCode": 302
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/seo/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=43200"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(sitemap.*|robots.txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
